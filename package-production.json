{
  "name": "enat-bank-invoice-service",
  "version": "1.0.0",
  "description": "Complete invoice generation service with PDF export for Enat Bank - Production Ready",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test-invoice.js",
    "test-db": "node test-db-connection.js",
    "test-connection": "node test-connection-methods.js",
    "test-real": "node test-real-connection.js",
    "debug-auth": "node debug-auth.js",
    "test-working": "node test-working-method.js",
    "test-ssms": "node test-ssms-method.js",
    "test-ports": "node test-port-discovery.js",
    "install-service": "node create-service.js",
    "pm2-start": "pm2 start server.js --name invoice-service",
    "pm2-stop": "pm2 stop invoice-service",
    "pm2-restart": "pm2 restart invoice-service",
    "pm2-logs": "pm2 logs invoice-service"
  },
  "dependencies": {
    "express": "^4.18.2",
    "html-pdf": "^3.0.1",
    "cors": "^2.8.5",
    "moment": "^2.29.4",
    "body-parser": "^1.20.2",
    "mssql": "^10.0.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "node-windows": "^1.0.0-beta.8"
  },
  "keywords": ["invoice", "pdf", "enat-bank", "amount-to-words", "sql-server", "production"],
  "author": "Enat Bank Invoice System",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
